<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-comarca-table" author="devjoaopr">

        <createTable tableName="comarca">

            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>

            <column name="state" type="varchar(63)">
                <constraints nullable="true"/>
            </column>

            <column name="slug" type="varchar(150)">
                <constraints nullable="true"/>
            </column>
            
            <column name="internal_id" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <column name="tj_id" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <column name="cnj_id" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <column name="judicial_rank" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <column name="active" type="boolean">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="timestamptz">
                <constraints nullable="true"/>
            </column>

            <column name="deleted_at" type="timestamptz">
                <constraints nullable="true"/>
            </column>

        </createTable>

    </changeSet>
</databaseChangeLog>